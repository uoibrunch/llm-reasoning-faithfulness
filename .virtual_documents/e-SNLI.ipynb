ax.autoscale()
ax.set_xlabel("Average ECS (windowed)")
ax.set_ylabel("Average Plausibility (Pmean, windowed)")  # <-- UPDATED LABEL
ax.set_title("Rolling Average ECS vs Pmean Plausibility (Density Weighted)")
ax.grid(alpha=0.3)

